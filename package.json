{
  "name": "redis-client",
  "version": "1.0.0",
  "description": "一个成熟、安全的 Redis 桌面管理工具",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^20.3.11",
    "electron-builder": "^24.13.3",
    "electron-store": "^8.1.0",
    "element-plus": "^2.4.4",
    "pinia": "^2.1.7",
    "redis": "^5.12.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue": "^3.5.13",
    "vue-tsc": "^1.8.27"
  },
  "build": {
    "appId": "com.redis.client",
    "productName": "Redis Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
